# ============================================================
# PayFlow Crypto — Environment Variables
# Copy this file to .env.local and fill in your API keys.
# NEVER commit .env.local to git.
# ============================================================

# ── Required ────────────────────────────────────────────────

# WalletConnect Project ID (from https://dashboard.reown.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Alchemy API Key (from https://alchemy.com)
# Used as RPC provider for Ethereum, Base, Polygon, Arbitrum
NEXT_PUBLIC_ALCHEMY_ID=

# 1inch API Key (from https://portal.1inch.dev)
# Used for swap quote aggregation — server-side only
ONEINCH_API_KEY=

# CoinGecko API Key (from https://coingecko.com/en/api)
# Used for token prices in USD/IDR — server-side only
COINGECKO_API_KEY=

# Prisma / SQLite database file path
DATABASE_URL="file:./dev.db"

# ── Optional ─────────────────────────────────────────────────

# Public app URL (defaults to localhost in development)
NEXT_PUBLIC_APP_URL=http://localhost:3000
